# Backend env (FastAPI)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
# Optional
# OPENROUTER_SITE_URL=https://your-frontend.vercel.app
# OPENROUTER_APP_NAME=IngrediScan AI

# Optional: LangSmith tracing (for LLM call observability)
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=ingrediscanai-dev

# Optional: Sentry (for backend error monitoring)
# SENTRY_DSN=https://xxxx@o000000.ingest.sentry.io/000000
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Comma-separated list of exact origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Optional regex for preview domains (leave empty to disable)
# For Vercel preview domains, you can set:
# CORS_ALLOWED_ORIGIN_REGEX=^https://.*\\.vercel\\.app$
CORS_ALLOWED_ORIGIN_REGEX=

# Render injects PORT automatically
# PORT=8000
