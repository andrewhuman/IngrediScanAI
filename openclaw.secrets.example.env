# Copy this file to a private location and fill real values.
# Do NOT commit real secrets to git.

# Required for backend runtime (Render)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# Deployment URLs
RENDER_BACKEND_URL=https://your-backend.onrender.com
VERCEL_FRONTEND_URL=https://your-frontend.vercel.app

# Render env values
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
# Optional: enable only when you need Vercel preview domains
CORS_ALLOWED_ORIGIN_REGEX=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ingrediscanai-production

# Vercel env values
NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Optional automation tokens (only if full automation is needed)
VERCEL_TOKEN=
RENDER_API_KEY=
GIT_PAT=
